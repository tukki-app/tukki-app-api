# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://covoiturage:password@localhost:5432/covoiturage

# Pour docker-compose (utilisé par le service postgres)
POSTGRES_DB=covoiturage
POSTGRES_USER=covoiturage
POSTGRES_PASSWORD=change_me_in_production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET=change_me_in_production_use_openssl_rand

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL=60

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Créer un compte sur https://cloudinary.com (gratuit)
# Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
